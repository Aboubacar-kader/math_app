# ============================================================
# VARIABLES D'ENVIRONNEMENT — IntelliMath
# Copier ce fichier en .env et remplir les valeurs réelles.
# Ne jamais commiter le fichier .env (il est dans .gitignore).
# ============================================================

# --- API 1min.ai / OpenAI -------------------------------------------
MIN_AI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
MIN_AI_MODEL=gpt-4o
MIN_AI_BASE_URL=https://api.openai.com/v1  # valeur par défaut dans settings.py
MIN_AI_TEMPERATURE=0.2

# --- Qdrant Cloud (vectorstore persistant) --------------------------
# Créer un cluster gratuit sur https://cloud.qdrant.io
QDRANT_URL=https://xxxx.eu-central-1-0.aws.cloud.qdrant.io
QDRANT_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx
QDRANT_COLLECTION_NAME=math_documents

# --- Qdrant local (ignoré si QDRANT_URL est défini) -----------------
QDRANT_PATH=./data/vectorstore

# --- Embeddings (modèle local, ne pas modifier) ---------------------
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Traitement des documents ---------------------------------------
MAX_FILE_SIZE_MB=50
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# --- Langue & voix --------------------------------------------------
SPEECH_LANG=fr-FR
TTS_LANG=fr

# --- Suppression des warnings HuggingFace ---------------------------
HF_HUB_DISABLE_IMPLICIT_TOKEN=1
TRANSFORMERS_VERBOSITY=error
